{
  "name": "unity-dll-bridge",
  "displayName": "Unity DLL Bridge",
  "description": "在 VSCode 中构建、校验并同步外部 C# DLL 到 Unity 工程。",
  "version": "0.1.0",
  "publisher": "xiaoyunhai0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/xiaoyunhai0/Unity-DLL-Bridge-for-VSCode.git",
    "directory": "vscode-extension"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "unity",
    "dll",
    "csharp",
    "vscode",
    "offline"
  ],
  "activationEvents": [
    "onView:unityDllBridge.actionsView",
    "workspaceContains:dllbridge.json",
    "workspaceContains:.dllbridge/dllbridge.json",
    "onCommand:unityDllBridge.validateConfiguration",
    "onCommand:unityDllBridge.syncOnly",
    "onCommand:unityDllBridge.openSyncLog",
    "onCommand:unityDllBridge.openManifest",
    "onCommand:unityDllBridge.openConfiguration",
    "onCommand:unityDllBridge.addProjectToUnitySolution",
    "onCommand:unityDllBridge.configureDotnetPath",
    "onCommand:unityDllBridge.openUnitySolution",
    "onCommand:unityDllBridge.discoverProjects",
    "onCommand:unityDllBridge.runEnvironmentDiagnostics",
    "onCommand:unityDllBridge.generateDebugConfig",
    "onCommand:unityDllBridge.toggleAutoBuild",
    "onCommand:unityDllBridge.configWizard",
    "onCommand:unityDllBridge.createConfigTemplate",
    "onCommand:unityDllBridge.selectConfiguration",
    "onCommand:unityDllBridge.buildProject",
    "onCommand:unityDllBridge.buildDllOnly",
    "onCommand:unityDllBridge.buildAndSync",
    "onCommand:unityDllBridge.buildAllProjects"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "unityDllBridge",
          "title": "DLL Bridge",
          "icon": "resources/dll-bridge.svg"
        }
      ]
    },
    "views": {
      "unityDllBridge": [
        {
          "id": "unityDllBridge.actionsView",
          "name": "工作台",
          "type": "webview",
          "visibility": "visible"
        }
      ]
    },
    "commands": [
      {
        "command": "unityDllBridge.validateConfiguration",
        "title": "Unity DLL Bridge: 校验配置"
      },
      {
        "command": "unityDllBridge.syncOnly",
        "title": "Unity DLL Bridge: 仅同步 DLL"
      },
      {
        "command": "unityDllBridge.openSyncLog",
        "title": "Unity DLL Bridge: 打开同步日志"
      },
      {
        "command": "unityDllBridge.openManifest",
        "title": "Unity DLL Bridge: 打开 Manifest"
      },
      {
        "command": "unityDllBridge.openConfiguration",
        "title": "Unity DLL Bridge: 打开配置文件"
      },
      {
        "command": "unityDllBridge.addProjectToUnitySolution",
        "title": "Unity DLL Bridge: 添加工程到 Unity 解决方案"
      },
      {
        "command": "unityDllBridge.configureDotnetPath",
        "title": "Unity DLL Bridge: 配置 dotnet 路径"
      },
      {
        "command": "unityDllBridge.openUnitySolution",
        "title": "Unity DLL Bridge: 打开 Unity 解决方案"
      },
      {
        "command": "unityDllBridge.discoverProjects",
        "title": "Unity DLL Bridge: 自动发现项目"
      },
      {
        "command": "unityDllBridge.runEnvironmentDiagnostics",
        "title": "Unity DLL Bridge: 一键诊断环境"
      },
      {
        "command": "unityDllBridge.generateDebugConfig",
        "title": "Unity DLL Bridge: 生成 Unity 调试配置"
      },
      {
        "command": "unityDllBridge.toggleAutoBuild",
        "title": "Unity DLL Bridge: 开关自动构建同步"
      },
      {
        "command": "unityDllBridge.configWizard",
        "title": "Unity DLL Bridge: 配置向导"
      },
      {
        "command": "unityDllBridge.createConfigTemplate",
        "title": "Unity DLL Bridge: 创建配置模板"
      },
      {
        "command": "unityDllBridge.selectConfiguration",
        "title": "Unity DLL Bridge: 选择 Debug/Release 配置"
      },
      {
        "command": "unityDllBridge.buildProject",
        "title": "Unity DLL Bridge: 生成当前工程 DLL"
      },
      {
        "command": "unityDllBridge.buildDllOnly",
        "title": "Unity DLL Bridge: 生成 DLL"
      },
      {
        "command": "unityDllBridge.buildAndSync",
        "title": "Unity DLL Bridge: 构建并同步"
      },
      {
        "command": "unityDllBridge.buildAllProjects",
        "title": "Unity DLL Bridge: 批量构建并同步"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "unityDllBridge.openConfiguration",
          "when": "view == unityDllBridge.actionsView",
          "group": "navigation"
        },
        {
          "command": "unityDllBridge.validateConfiguration",
          "when": "view == unityDllBridge.actionsView",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "node ../scripts/package-extension.js",
    "release:local": "npm run compile && npm run package && node ../scripts/create-release-artifacts.js"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.24.0",
    "typescript": "^5.4.5"
  }
}
