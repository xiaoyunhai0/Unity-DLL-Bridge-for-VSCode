{
  "name": "unity-dll-bridge",
  "displayName": "Unity DLL Bridge",
  "description": "在 VSCode 中构建、校验并同步外部 C# DLL 到 Unity 工程。",
  "version": "0.1.0",
  "publisher": "xiaoyunhai0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/xiaoyunhai0/Unity-DLL-Bridge-for-VSCode.git",
    "directory": "vscode-extension"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "unity",
    "dll",
    "csharp",
    "vscode",
    "offline"
  ],
  "activationEvents": [
    "onView:unityDllBridge.actionsView",
    "workspaceContains:dllbridge.json",
    "workspaceContains:.dllbridge/dllbridge.json",
    "onCommand:unityDllBridge.validateConfiguration",
    "onCommand:unityDllBridge.syncOnly",
    "onCommand:unityDllBridge.openSyncLog",
    "onCommand:unityDllBridge.openManifest",
    "onCommand:unityDllBridge.openConfiguration",
    "onCommand:unityDllBridge.createConfigTemplate",
    "onCommand:unityDllBridge.selectConfiguration",
    "onCommand:unityDllBridge.buildDllOnly",
    "onCommand:unityDllBridge.buildAndSync"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "unityDllBridge",
          "title": "DLL Bridge",
          "icon": "resources/dll-bridge.svg"
        }
      ]
    },
    "views": {
      "unityDllBridge": [
        {
          "id": "unityDllBridge.actionsView",
          "name": "工作台"
        }
      ]
    },
    "commands": [
      {
        "command": "unityDllBridge.validateConfiguration",
        "title": "Unity DLL Bridge: Validate Configuration"
      },
      {
        "command": "unityDllBridge.syncOnly",
        "title": "Unity DLL Bridge: Sync Only"
      },
      {
        "command": "unityDllBridge.openSyncLog",
        "title": "Unity DLL Bridge: Open Sync Log"
      },
      {
        "command": "unityDllBridge.openManifest",
        "title": "Unity DLL Bridge: Open Manifest"
      },
      {
        "command": "unityDllBridge.openConfiguration",
        "title": "Unity DLL Bridge: Open Configuration"
      },
      {
        "command": "unityDllBridge.createConfigTemplate",
        "title": "Unity DLL Bridge: Create Config Template"
      },
      {
        "command": "unityDllBridge.selectConfiguration",
        "title": "Unity DLL Bridge: Select Configuration"
      },
      {
        "command": "unityDllBridge.buildDllOnly",
        "title": "Unity DLL Bridge: Build DLL Only"
      },
      {
        "command": "unityDllBridge.buildAndSync",
        "title": "Unity DLL Bridge: Build & Sync"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "unityDllBridge.openConfiguration",
          "when": "view == unityDllBridge.actionsView",
          "group": "navigation"
        },
        {
          "command": "unityDllBridge.validateConfiguration",
          "when": "view == unityDllBridge.actionsView",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "node ../scripts/package-extension.js",
    "release:local": "npm run compile && npm run package && node ../scripts/create-release-artifacts.js"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.24.0",
    "typescript": "^5.4.5"
  }
}
